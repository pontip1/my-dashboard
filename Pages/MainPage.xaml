<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyDashboard.MainPage"
             BackgroundColor="#F4F7FB">

    <Grid>
        <Border
            StrokeThickness="0"
            BackgroundColor="White"
            Padding="40"
            Margin="30"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            MaximumWidthRequest="520">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="28"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="24">

                <Label Text="MyDashboard"
                       FontSize="40"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="#1F2937"/>

                <Label Text="Manage rooms, tasks and achievements in one place"
                       FontSize="18"
                       HorizontalTextAlignment="Center"
                       TextColor="#6B7280"/>

                <BoxView HeightRequest="1"
                         Color="#E5E7EB"
                         Margin="0,6,0,6"/>

                <Button Text="Create account"
                        Clicked="NewAccount_Clicked"
                        HeightRequest="60"
                        CornerRadius="16"
                        FontSize="22"
                        FontAttributes="Bold"
                        BackgroundColor="#4F46E5"
                        TextColor="White"/>

                <Button Text="Login"
                        Clicked="Login_Clicked"
                        HeightRequest="60"
                        CornerRadius="16"
                        FontSize="22"
                        FontAttributes="Bold"
                        BackgroundColor="#EEF2FF"
                        TextColor="#3730A3"/>

            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>