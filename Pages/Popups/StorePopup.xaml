<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MyDashboard.Pages.Popups.StorePopup">

    <Border BackgroundColor="White"
            StrokeThickness="0"
            Padding="24"
            WidthRequest="520">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="16">

            <Label Text="Store"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="#111827"/>

            <Label Text="Spend your shop points on rewards"
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="#6B7280"/>

            <Border BackgroundColor="#EEF2FF"
                    StrokeThickness="0"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <Label x:Name="MyShopPointsLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="#3730A3"/>
            </Border>

            <ScrollView HeightRequest="420">
                <VerticalStackLayout x:Name="ShopItemsList"
                                     Spacing="12"/>
            </ScrollView>

            <Button Text="Close"
                    Clicked="Close_Clicked"
                    HeightRequest="52"
                    CornerRadius="14"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#EEF2FF"
                    TextColor="#3730A3"/>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>