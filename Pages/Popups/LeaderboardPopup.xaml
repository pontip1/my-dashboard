<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MyDashboard.Pages.Popups.LeaderboardPopup">

    <Border BackgroundColor="White"
            StrokeThickness="0"
            Padding="24"
            WidthRequest="500">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="16">

            <Label Text="Leaderboard"
                   FontSize="30"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="#111827"/>

            <Label Text="Top users by points"
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="#6B7280"/>

            <Border BackgroundColor="#EEF2FF"
                    StrokeThickness="0"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <Label x:Name="MyPointsLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="#3730A3"/>
            </Border>

            <Grid ColumnDefinitions="50,*,Auto"
                  Padding="6,0"
                  ColumnSpacing="10">
                <Label Text="#"
                       FontAttributes="Bold"
                       TextColor="#6B7280"/>
                <Label Grid.Column="1"
                       Text="User"
                       FontAttributes="Bold"
                       TextColor="#6B7280"/>
                <Label Grid.Column="2"
                       Text="Points"
                       FontAttributes="Bold"
                       TextColor="#6B7280"/>
            </Grid>

            <BoxView HeightRequest="1"
                     Color="#E5E7EB"/>

            <ScrollView HeightRequest="360">
                <VerticalStackLayout x:Name="LeaderboardList"
                                     Spacing="10"/>
            </ScrollView>

            <Button Text="Close"
                    Clicked="Close_Clicked"
                    HeightRequest="52"
                    CornerRadius="14"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#EEF2FF"
                    TextColor="#3730A3"/>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>