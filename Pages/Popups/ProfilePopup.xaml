<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MyDashboard.Pages.Popups.ProfilePopup">

    <Border BackgroundColor="White"
            StrokeThickness="0"
            Padding="24"
            WidthRequest="500">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="24"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="18">

            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="10">

                <Label Text="Profile"
                       FontSize="30"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="#111827"/>

                <Button Grid.Column="1"
                        Text="Logout"
                        Clicked="Logout_Clicked"
                        HeightRequest="48"
                        CornerRadius="14"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="#FEE2E2"
                        TextColor="#B91C1C"/>

                <Button Grid.Column="2"
                        Text="Close"
                        Clicked="Close_Clicked"
                        HeightRequest="48"
                        CornerRadius="14"
                        FontSize="16"
                        FontAttributes="Bold"
                        BackgroundColor="#EEF2FF"
                        TextColor="#3730A3"/>
            </Grid>

            <BoxView HeightRequest="1"
                     Color="#E5E7EB"/>

            <VerticalStackLayout Spacing="8">
                <Label Text="Email"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#374151"/>

                <Border BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        Padding="14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>

                    <Label x:Name="EmailField"
                           FontSize="18"
                           TextColor="#111827"/>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Name"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#374151"/>

                <Entry x:Name="NameField"
                       Placeholder="Enter your name"
                       FontSize="18"
                       HeightRequest="54"
                       BackgroundColor="#F9FAFB"
                       TextColor="#111827"
                       PlaceholderColor="#9CA3AF"/>
            </VerticalStackLayout>

            <Button Text="Apply changes"
                    Clicked="ApplyButton_Clicked"
                    HeightRequest="54"
                    CornerRadius="14"
                    FontSize="18"
                    FontAttributes="Bold"
                    BackgroundColor="#4F46E5"
                    TextColor="White"/>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>