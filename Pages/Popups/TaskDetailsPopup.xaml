<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="MyDashboard.Pages.TaskDetailsPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20">

        <ScrollView WidthRequest="420">
            <VerticalStackLayout WidthRequest="420"
                                 Padding="24"
                                 Spacing="18">

                <Label x:Name="TaskNameLabel"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       HorizontalOptions="Center" />

                <Border BackgroundColor="#F9FAFB"
                        Stroke="#E5E7EB"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 14"
                        Padding="14,12">

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Description"
                               FontSize="13"
                               TextColor="#6B7280" />

                        <Label x:Name="TaskDescriptionLabel"
                               FontSize="16"
                               TextColor="#111827"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout Spacing="12">
                    <Border BackgroundColor="#F0FDF4"
                            Stroke="#BBF7D0"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,10"
                            HorizontalOptions="FillAndExpand">

                        <Label x:Name="TaskPointsLabel"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#15803D" />
                    </Border>

                    <Border BackgroundColor="#F9FAFB"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,10"
                            HorizontalOptions="FillAndExpand">

                        <Label x:Name="TaskAssignedLabel"
                               FontSize="14"
                               TextColor="#374151"
                               LineBreakMode="WordWrap" />
                    </Border>
                </HorizontalStackLayout>

                <VerticalStackLayout x:Name="AnswerEditorBlock"
                                     Spacing="8"
                                     IsVisible="False">
                    <Label Text="Your answer"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151" />

                    <Editor x:Name="AnswerEditor"
                            HeightRequest="120"
                            BackgroundColor="#F9FAFB"
                            TextColor="#111827"
                            Placeholder="Enter your answer"
                            PlaceholderColor="#9CA3AF" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8"
                                     IsVisible="False"
                                     x:Name="AnswerViewBlock">
                    <Label x:Name="AnswerTitleLabel"
                           Text="User answer"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151"
                           IsVisible="False" />

                    <Border BackgroundColor="#F9FAFB"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,12"
                            IsVisible="False"
                            x:Name="TaskAnswerBorder">

                        <Label x:Name="TaskAnswerLabel"
                               TextColor="#111827"
                               LineBreakMode="WordWrap"
                               IsVisible="False" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8"
                                     IsVisible="False"
                                     x:Name="ReviewCommentBlock">
                    <Label x:Name="ReviewCommentTitleLabel"
                           Text="Admin comment"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151"
                           IsVisible="False" />

                    <Editor x:Name="ReviewCommentEditor"
                            HeightRequest="100"
                            BackgroundColor="#F9FAFB"
                            TextColor="#111827"
                            Placeholder="Enter comment"
                            PlaceholderColor="#9CA3AF"
                            IsVisible="False" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8"
                                     IsVisible="False"
                                     x:Name="ReturnedCommentBlock">
                    <Label x:Name="ReturnedCommentTitleLabel"
                           Text="Comment from owner"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#B45309"
                           IsVisible="False" />

                    <Border BackgroundColor="#FFF7ED"
                            Stroke="#FED7AA"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 14"
                            Padding="14,12"
                            IsVisible="False"
                            x:Name="ReturnedCommentBorder">

                        <Label x:Name="ReturnedCommentLabel"
                               TextColor="#C2410C"
                               LineBreakMode="WordWrap"
                               IsVisible="False" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">

                    <Button x:Name="TakeTaskButton"
                            Text="Take task"
                            Clicked="TakeTask_Clicked"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#5B3FD0"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button x:Name="GoToReviewButton"
                            Text="Go to review"
                            Clicked="GoToReview_Clicked"
                            IsVisible="False"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#5B3FD0"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button x:Name="AcceptButton"
                            Text="Done"
                            Clicked="Accept_Clicked"
                            IsVisible="False"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#16A34A"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button x:Name="ReturnButton"
                            Text="Return to in progress"
                            Clicked="Return_Clicked"
                            IsVisible="False"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#F59E0B"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button x:Name="DeleteTaskButton"
                            Text="Delete task"
                            Clicked="DeleteTask_Clicked"
                            IsVisible="False"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="#DC2626"
                            TextColor="White"
                            FontAttributes="Bold" />

                    <Button Text="Close"
                            Clicked="Close_Clicked"
                            HeightRequest="46"
                            BackgroundColor="Transparent"
                            TextColor="#6B7280" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>