<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyDashboard.Pages.RegisterPage"
             Title="Register"
             BackgroundColor="#F4F7FB">

    <ScrollView>
        <Grid Padding="20">
            <Border
                StrokeThickness="0"
                BackgroundColor="White"
                Padding="36"
                Margin="10"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                MaximumWidthRequest="520">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">

                    <Label Text="Create account"
                           FontSize="34"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#1F2937"/>

                    <Label Text="Register to start using MyDashboard"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="#6B7280"
                           Margin="0,0,0,10"/>

                    <Label Text="Email"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#374151"/>

                    <Entry x:Name="Email"
                           Placeholder="Enter your email"
                           Keyboard="Email"
                           FontSize="18"
                           BackgroundColor="#F9FAFB"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           HeightRequest="56" />

                    <Label Text="Name"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#374151"/>

                    <Entry x:Name="Name"
                           Placeholder="Enter your name"
                           FontSize="18"
                           BackgroundColor="#F9FAFB"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           HeightRequest="56" />

                    <Label Text="Password"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#374151"/>

                    <Entry x:Name="Password"
                           IsPassword="True"
                           Placeholder="Enter your password"
                           FontSize="18"
                           BackgroundColor="#F9FAFB"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           HeightRequest="56" />

                    <Label Text="Confirm password"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#374151"/>

                    <Entry x:Name="PasswordConfirm"
                           IsPassword="True"
                           Placeholder="Repeat your password"
                           FontSize="18"
                           BackgroundColor="#F9FAFB"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF"
                           HeightRequest="56" />

                    <Button x:Name="RegisterButton"
                            Text="Create account"
                            Clicked="Register_Clicked"
                            HeightRequest="58"
                            Margin="0,10,0,0"
                            CornerRadius="16"
                            FontSize="22"
                            FontAttributes="Bold"
                            BackgroundColor="#4F46E5"
                            TextColor="White"/>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>